#!/usr/bin/env bash
###############################################################################
# omp-sbx-parallel — launch a parallel omp session in a git worktree.
#
#   $ omp-sbx-parallel              # → pick/create a branch, open worktree+sandbox
#   $ omp-sbx-parallel --branch fix-bug   # → skip picker, use existing branch
#   $ omp-sbx-parallel --new feature-x    # → create new branch, open worktree+sandbox
#
# Creates a git worktree on the chosen branch, then launches a separate sbx
# sandbox with that worktree as the workspace. Each parallel session gets its
# own sandbox (visible in `sbx ls`) and can commit/push independently.
#
# Worktrees are created as siblings of the repo root:
#   ~/src/myproject          ← main worktree (main branch)
#   ~/src/myproject@fix-bug  ← parallel worktree (fix-bug branch)
#
# On exit, you're offered cleanup: merge the branch back and remove the worktree,
# or leave it for later.
###############################################################################
set -euo pipefail

# Resolve the repo root from the script's location (portable symlink resolution).
SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  case "$SCRIPT_PATH" in /*) ;; *) SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH" ;; esac
done
REPO_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
KIT_DIR="${OMP_SBX_KIT:-$REPO_DIR/sbx-kit}"
TEMPLATE="${OMP_SBX_TEMPLATE:-omp-sbx:latest}"

# Colors (only when stderr is a tty)
if [ -t 2 ]; then
  C_DIM=$'\033[2m'; C_CYAN=$'\033[36m'; C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_BOLD=$'\033[1m'; C_RST=$'\033[0m'
else
  C_DIM=''; C_CYAN=''; C_GREEN=''; C_YELLOW=''; C_RED=''; C_BOLD=''; C_RST=''
fi
log() { printf '%s\n' "$*" >&2; }

# ── Parse flags ──────────────────────────────────────────────────────────────
BRANCH=""
CREATE_NEW=""
SKIP_PAUSE=false
OMP_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --branch) CREATE_NEW="existing" ;;
    --new)    CREATE_NEW="new" ;;
    --yes|-y) SKIP_PAUSE=true ;;
    --help|-h)
      sed -n '2,/^###/p' "$0" | sed 's/^# \?//' >&2
      exit 0
      ;;
    *)
      # Skip the -- separator (it's for sbx run, not needed for sbx exec or omp)
      [ "$arg" = "--" ] && continue
      if [ "$CREATE_NEW" = "existing" ] || [ "$CREATE_NEW" = "new" ]; then
        if [ -z "$BRANCH" ]; then
          BRANCH="$arg"
        else
          OMP_ARGS+=("$arg")
        fi
      else
        OMP_ARGS+=("$arg")
      fi
      ;;
  esac
done
if [ ${#OMP_ARGS[@]} -gt 0 ]; then set -- "${OMP_ARGS[@]}"; else set --; fi

# ── Preflight ────────────────────────────────────────────────────────────────
# shellcheck source=sbx-preflight.sh
source "$REPO_DIR/sbx-preflight.sh"
ensure_sbx "omp-sbx-parallel"

if ! command -v git >/dev/null 2>&1; then
  log "${C_RED}omp-sbx-parallel: git not found${C_RST}"
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  log "${C_RED}omp-sbx-parallel: not inside a git repository${C_RST}"
  exit 1
fi

if [ ! -d "$HOME/.omp" ]; then
  log "${C_RED}omp-sbx-parallel: host config dir not found: $HOME/.omp${C_RST}"
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
REPO_BASE="$(basename "$REPO_ROOT")"
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"

# ── Branch picker ────────────────────────────────────────────────────────────
# If --branch <name> or --new <name> was given, use it directly.
# Otherwise, show an interactive picker (fzf if available, fallback to numbered list).

pick_branch() {
  local action="$1"  # "existing" | "new"
  local selected=""

  if [ "$action" = "existing" ]; then
    # List local branches (excluding current), let user pick
    local branches
    branches=$(git for-each-ref --format='%(refname:short)' refs/heads/ | grep -v "^${CURRENT_BRANCH}$" || true)

    if [ -z "$branches" ]; then
      log "${C_YELLOW}No other local branches. Use --new <name> to create one.${C_RST}"
      exit 1
    fi

    if command -v fzf >/dev/null 2>&1 && [ -t 0 ]; then
      selected=$(echo "$branches" | fzf --prompt="select branch> " --height=40% --reverse --no-multi) || {
        log "${C_DIM}cancelled${C_RST}"
        exit 0
      }
    elif [ -t 0 ]; then
      # Fallback: numbered list
      log "${C_BOLD}Select a branch:${C_RST}"
      local i=1
      local branch_array=()
      while IFS= read -r b; do
        branch_array+=("$b")
        printf '  %d) %s\n' "$i" "$b" >&2
        i=$((i + 1))
      done <<< "$branches"
      printf '  0) cancel\n' >&2
      printf '> ' >&2
      read -r choice < /dev/tty
      [ "$choice" = "0" ] && { log "${C_DIM}cancelled${C_RST}"; exit 0; }
      if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#branch_array[@]}" ]; then
        selected="${branch_array[$((choice - 1))]}"
      else
        log "${C_RED}invalid selection${C_RST}"
        exit 1
      fi
    else
      log "${C_RED}no TTY for interactive picker; use --branch <name>${C_RST}"
      exit 1
    fi
  else
    # New branch: prompt for name
    if [ -t 0 ]; then
      printf '%sEnter new branch name: %s' "$C_GREEN" "$C_RST" >&2
      read -r selected < /dev/tty
    else
      log "${C_RED}no TTY; use --new <branch-name>${C_RST}"
      exit 1
    fi
    [ -z "$selected" ] && { log "${C_DIM}cancelled${C_RST}"; exit 0; }
    # Validate branch name
    if ! git check-ref-format --normalize "refs/heads/$selected" >/dev/null 2>&1; then
      log "${C_RED}invalid branch name: $selected${C_RST}"
      exit 1
    fi
  fi

  echo "$selected"
}

if [ -z "$BRANCH" ]; then
  # No branch specified — interactive picker
  if [ -t 0 ]; then
    log "${C_BOLD}omp-sbx-parallel${C_RST} — parallel omp session in a git worktree"
    log ""
    log "  1) Use existing branch"
    log "  2) Create new branch"
    log ""
    printf '> ' >&2
    read -r choice < /dev/tty
    case "$choice" in
      1) BRANCH=$(pick_branch "existing"); CREATE_NEW="existing" ;;
      2) BRANCH=$(pick_branch "new"); CREATE_NEW="new" ;;
      *) log "${C_DIM}cancelled${C_RST}"; exit 0 ;;
    esac
  else
    log "${C_RED}no TTY; specify --branch <name> or --new <name>${C_RST}"
    exit 1
  fi
elif [ "$CREATE_NEW" = "new" ]; then
  # --new <name> — validate it doesn't already exist
  if git show-ref --verify --quiet "refs/heads/$BRANCH" 2>/dev/null; then
    log "${C_RED}branch '$BRANCH' already exists; use --branch $BRANCH to use it${C_RST}"
    exit 1
  fi
  # Create the worktree on the new branch (no picker needed)
  :
else
  # --branch <name> — validate it exists
  if ! git show-ref --verify --quiet "refs/heads/$BRANCH" 2>/dev/null; then
    log "${C_RED}branch '$BRANCH' not found${C_RST}"
    log "${C_DIM}available branches:${C_RST}"
    git for-each-ref --format='  %(refname:short)' refs/heads/ >&2
    exit 1
  fi
fi

# ── Create worktree ──────────────────────────────────────────────────────────
WORKTREE_PATH="${REPO_ROOT%@*}"  # strip any existing @suffix
WORKTREE_PATH="${WORKTREE_PATH}@${BRANCH//\//-}"

# Check if worktree already exists (e.g. from a previous run)
if [ -d "$WORKTREE_PATH" ]; then
  log "${C_DIM}omp-sbx-parallel: worktree already exists at $WORKTREE_PATH${C_RST}"
  # Verify it's a valid worktree for this branch
  if git worktree list --porcelain | grep -q "worktree ${WORKTREE_PATH}"; then
    log "${C_DIM}reusing existing worktree${C_RST}"
  else
    log "${C_YELLOW}path exists but is not a git worktree; choose a different location${C_RST}"
    exit 1
  fi
else
  if [ "$CREATE_NEW" = "new" ]; then
    log "${C_DIM}creating worktree on new branch '$BRANCH'...${C_RST}"
    git worktree add -b "$BRANCH" "$WORKTREE_PATH" 2>&1 | sed 's/^/  /' >&2
  else
    log "${C_DIM}creating worktree on existing branch '$BRANCH'...${C_RST}"
    git worktree add "$WORKTREE_PATH" "$BRANCH" 2>&1 | sed 's/^/  /' >&2
  fi
fi

# ── VS Code workspace file management ────────────────────────────────────────
# Maintain a multi-root .code-workspace at the repo root so VS Code can display
# all worktrees as named roots. The file is gitignored (*.code-workspace).
# Requires jq on the host; silently skips if unavailable.
WORKSPACE_FILE="$REPO_ROOT/$REPO_BASE.code-workspace"

init_code_workspace() {
  if [ ! -f "$WORKSPACE_FILE" ]; then
    cat > "$WORKSPACE_FILE" <<EOF
{
  "folders": [
    { "path": ".", "name": "$REPO_BASE" }
  ],
  "settings": {}
}
EOF
    log "${C_DIM}created $WORKSPACE_FILE${C_RST}"
  fi
}

add_worktree_to_workspace() {
  local branch="$1"
  local wt_path="$2"
  local folder_name="$REPO_BASE $branch"
  local rel_path="../$(basename "$wt_path")"

  if ! command -v jq >/dev/null 2>&1; then
    log "${C_YELLOW}jq not found — skipping .code-workspace update${C_RST}"
    return 0
  fi
  init_code_workspace
  # Idempotent: remove existing entry for this branch, then add.
  jq --arg name "$folder_name" --arg path "$rel_path" \
    '.folders |= map(select(.name != $name)) + [{"path": $path, "name": $name}]' \
    "$WORKSPACE_FILE" > "$WORKSPACE_FILE.tmp" && mv "$WORKSPACE_FILE.tmp" "$WORKSPACE_FILE"
  log "${C_DIM}added '$folder_name' to $REPO_BASE.code-workspace${C_RST}"
}

remove_worktree_from_workspace() {
  local branch="$1"
  local folder_name="$REPO_BASE $branch"

  if [ ! -f "$WORKSPACE_FILE" ] || ! command -v jq >/dev/null 2>&1; then
    return 0
  fi
  jq --arg name "$folder_name" \
    '.folders |= map(select(.name != $name))' \
    "$WORKSPACE_FILE" > "$WORKSPACE_FILE.tmp" && mv "$WORKSPACE_FILE.tmp" "$WORKSPACE_FILE"
  log "${C_DIM}removed '$folder_name' from $REPO_BASE.code-workspace${C_RST}"
}

add_worktree_to_workspace "$BRANCH" "$WORKTREE_PATH"

# ── Sandbox name (unique per worktree) ───────────────────────────────────────
SANDBOX_NAME="omp-$(echo "${REPO_BASE}-${BRANCH}" | tr -cd '[:alnum:]_-')"

# ── Banner ───────────────────────────────────────────────────────────────────
log ""
log "${C_BOLD}${C_CYAN}╭─ omp-sbx-parallel ───────────────────────────────────────╮${C_RST}"
log "${C_CYAN}│${C_RST} template  : ${TEMPLATE}"
log "${C_CYAN}│${C_RST} repo      : ${REPO_ROOT}"
log "${C_CYAN}│${C_RST} branch    : ${BRANCH}  ${C_DIM}(from ${CURRENT_BRANCH})${C_RST}"
log "${C_CYAN}│${C_RST} worktree  : ${WORKTREE_PATH}  ${C_DIM}→ /home/agent/workspace${C_RST}"
log "${C_CYAN}│${C_RST} config    : ${HOME}/.omp  ${C_DIM}(shared, via symlink)${C_RST}"
log "${C_CYAN}│${C_RST} sandbox   : ${SANDBOX_NAME}"
if [ "$#" -eq 0 ]; then
  log "${C_CYAN}│${C_RST} mode      : ${C_GREEN}interactive TUI${C_RST}"
else
  log "${C_CYAN}│${C_RST} mode      : ${C_GREEN}omp $*${C_RST}"
fi
log "${C_BOLD}${C_CYAN}╰─ starting omp in parallel worktree sandbox ───────────────╯${C_RST}"
log ""

# ── Cleanup trap ─────────────────────────────────────────────────────────────
# On exit (interactive mode only), offer to merge + clean up the worktree.
cleanup() {
  local rc=$?
  if [ "$#" -eq 0 ] && [ -t 0 ] && [ $rc -eq 0 ]; then
    log ""
    log "${C_BOLD}omp-sbx-parallel: session ended${C_RST}"
    log "  worktree: ${C_DIM}${WORKTREE_PATH}${C_RST}"
    log "  branch:   ${C_DIM}${BRANCH}${C_RST}"
    log ""
    log "  1) Merge '${BRANCH}' into '${CURRENT_BRANCH}' and remove worktree"
    log "  2) Remove worktree only (keep branch)"
    log "  3) Remove worktree AND branch '${BRANCH}' (no merge) ${C_RED}[destructive]${C_RST}"
    log "  4) Keep worktree as-is"
    log "  0) Do nothing"
    printf '> ' >&2
    read -r choice < /dev/tty
    case "$choice" in
      1)
        cd "$REPO_ROOT"
        git merge "$BRANCH" 2>&1 | sed 's/^/  /' >&2
        git worktree remove "$WORKTREE_PATH" 2>&1 | sed 's/^/  /' >&2
        git branch -d "$BRANCH" 2>&1 | sed 's/^/  /' >&2
        remove_worktree_from_workspace "$BRANCH"
        log "${C_GREEN}✓ merged and cleaned up${C_RST}"
        ;;
      2)
        git worktree remove "$WORKTREE_PATH" 2>&1 | sed 's/^/  /' >&2
        remove_worktree_from_workspace "$BRANCH"
        log "${C_GREEN}✓ worktree removed (branch '${BRANCH}' kept)${C_RST}"
        ;;
      3)
        log ""
        log "${C_RED}⚠  This will permanently remove the worktree AND delete the branch '${BRANCH}'.${C_RST}"
        log "${C_RED}   Any unmerged commits on '${BRANCH}' will be LOST.${C_RST}"
        log ""
        log "${C_BOLD}Type 'yes' to confirm (3s guard before input)...${C_RST}"
        log "${C_DIM}waiting 3 seconds...${C_RST}"
        sleep 3
        printf '%sconfirm> %s' "$C_GREEN" "$C_RST" >&2
        read -r confirm < /dev/tty
        case "$confirm" in
          [Yy][Ee][Ss])
            git worktree remove "$WORKTREE_PATH" 2>&1 | sed 's/^/  /' >&2
            git branch -D "$BRANCH" 2>&1 | sed 's/^/  /' >&2
            remove_worktree_from_workspace "$BRANCH"
            log "${C_GREEN}✓ worktree and branch '${BRANCH}' removed${C_RST}"
            ;;
          *)
            log "${C_YELLOW}aborted: worktree and branch left intact${C_RST}"
            ;;
        esac
        ;;
      4)
        log "${C_DIM}worktree kept at ${WORKTREE_PATH}${C_RST}"
        ;;
      *) ;;
    esac
  fi
  # Always tear down the sbx sandbox instance on quit (ephemeral per session).
  sbx rm -f "$SANDBOX_NAME" 2>/dev/null && log "${C_DIM}sandbox '${SANDBOX_NAME}' removed${C_RST}" || true
  exit $rc
}

# ── Launch ───────────────────────────────────────────────────────────────────
sandbox_exists() {
  # Use awk to match the SANDBOX column exactly (avoids false positives
  # like omp-Foo matching omp-Foo-parallel2).
  sbx ls 2>/dev/null | awk -v name="$1" 'NR>1 && $1 == name {found=1} END {exit !found}'
}

# Two-phase approach for interactive mode:
#   1. sbx create (non-interactive) — captures warnings to stderr where the
#      user can read them before omp clears the screen.
#   2. Pause — "press any key" gives time to read the warnings.
#   3. sbx run --name (attaches to TUI) — omp launches and clears screen.
# The main repo's .git dir is mounted rw so git worktree operations (commit,
# branch, log, push) work inside the container.
if [ "$#" -eq 0 ] && [ -t 0 ]; then
  # Interactive TUI — install the cleanup trap once so it covers every exit
  # path (create failure, re-attach failure, or clean session end).
  trap cleanup EXIT
  if ! sandbox_exists "$SANDBOX_NAME"; then
    # Phase 1: create the sandbox, surfacing warnings on stderr. Capture the
    # output so a failed create can be classified: a "name already taken"
    # error is a false negative from sandbox_exists — after a force-quit the
    # sandbox is left stopped, and sbx ls may omit stopped sandboxes, so the
    # name match missed it and create collided with the existing name.
    # Recover by re-attaching (Phase 3) instead of erroring out.
    if create_out="$(sbx create --kit "$KIT_DIR" --template "$TEMPLATE" --name "$SANDBOX_NAME" \
        omp "$WORKTREE_PATH" "$HOME/.omp" "${REPO_ROOT}/.git" 2>&1)"; then
      if [ -n "$create_out" ]; then printf '%s\n' "$create_out" >&2; fi
      sleep 2
    else
      if [ -n "$create_out" ]; then printf '%s\n' "$create_out" >&2; fi
      if printf '%s' "$create_out" | grep -qiE 'already exists|given new workspaces'; then
        log "${C_DIM}omp-sbx-parallel: sandbox already exists (stopped?), will re-attach${C_RST}"
      else
        log "${C_RED}omp-sbx-parallel: failed to create sandbox${C_RST}"
        exit 1
      fi
    fi
  fi

  # Phase 2: pause so the user can read sbx warnings before omp clears screen.
  if ! $SKIP_PAUSE; then
    log ""
    log "${C_GREEN}Press any key to launch omp (or --yes to skip this)...${C_RST}"
    read -rsn1 < /dev/tty
    log ""
  fi

  # Phase 3: attach to the sandbox TUI. sbx run --name re-attaches to a running
  # agent or restarts a stopped sandbox's agent. If re-attach fails (a
  # force-quit can leave the agent process wedged), stop+restart; last resort
  # rm+recreate. omp session state lives in the shared ~/.omp mount, so the
  # conversation resumes even across a recreate.
  if ! sbx run --kit "$KIT_DIR" --name "$SANDBOX_NAME" 2>&1; then
    log "${C_DIM}omp-sbx-parallel: re-attach failed; restarting sandbox...${C_RST}"
    sbx stop "$SANDBOX_NAME" >/dev/null 2>&1 || true
    if ! sbx run --kit "$KIT_DIR" --name "$SANDBOX_NAME" 2>&1; then
      log "${C_DIM}omp-sbx-parallel: sandbox unresponsive, recreating...${C_RST}"
      sbx rm -f "$SANDBOX_NAME" >/dev/null 2>&1 || true
      if ! sbx create --kit "$KIT_DIR" --template "$TEMPLATE" --name "$SANDBOX_NAME" \
          omp "$WORKTREE_PATH" "$HOME/.omp" "${REPO_ROOT}/.git" 2>&1; then
        log "${C_RED}omp-sbx-parallel: failed to create sandbox${C_RST}"
        exit 1
      fi
      sleep 2
      exec sbx run --kit "$KIT_DIR" --name "$SANDBOX_NAME"
    fi
  fi
else
  # Non-interactive — create if needed, then exec omp with args.
  if ! sandbox_exists "$SANDBOX_NAME"; then
    # Same false-negative recovery as interactive mode: a create failure here
    # is usually a name collision with a stopped sandbox left by a force-quit.
    # sbx exec starts a stopped sandbox, so fall through and let it run.
    if ! sbx create --kit "$KIT_DIR" --template "$TEMPLATE" --name "$SANDBOX_NAME" \
        omp "$WORKTREE_PATH" "$HOME/.omp" "${REPO_ROOT}/.git" >/dev/null 2>&1; then
      : # already exists or transient — sbx exec surfaces real errors
    else
      sleep 2
    fi
  fi
  exec sbx exec "$SANDBOX_NAME" omp "$@"
fi
